# Smart Mandi API — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control

# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smart_mandi
DB_USER=smart_mandi_user
DB_PASSWORD=your_secure_password_here
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_IDEMPOTENCY_TTL=86400

# JWT — Use RS256 in production (generate with: openssl genrsa -out private.pem 2048)
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789/smart-mandi-events
SQS_DLQ_URL=https://sqs.ap-south-1.amazonaws.com/123456789/smart-mandi-events-dlq
SQS_MAX_RECEIVE_COUNT=5

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100
