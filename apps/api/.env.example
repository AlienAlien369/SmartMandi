# Smart Mandi API — Environment Variables Reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# This file is committed to version control — NEVER put real secrets here.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development                    # development | staging | production
PORT=3000
API_PREFIX=api/v1

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432                            # Docker dev default: 5433
DB_NAME=smart_mandi
DB_USER=smart_mandi_user
DB_PASSWORD=<your_secure_db_password>
DB_SSL=false                            # Set to true for RDS / managed Postgres
DB_POOL_MIN=2
DB_POOL_MAX=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                         # Leave empty if no auth (local dev)
REDIS_DB=0
REDIS_IDEMPOTENCY_TTL=86400             # 24h — idempotency key expiry in seconds

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Production: switch to RS256 — generate key pair:
#   openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_SECRET=<generate_with_crypto_randomBytes_48>
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=<your_iam_access_key_id>
AWS_SECRET_ACCESS_KEY=<your_iam_secret_access_key>

# SQS — replace <ACCOUNT_ID> with your 12-digit AWS account ID
# Find it: aws sts get-caller-identity --query Account --output text
SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/<ACCOUNT_ID>/smart-mandi-events
SQS_DLQ_URL=https://sqs.ap-south-1.amazonaws.com/<ACCOUNT_ID>/smart-mandi-events-dlq
SQS_MAX_RECEIVE_COUNT=5

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60                         # Window size in seconds
THROTTLE_LIMIT=100                      # Max requests per window per IP

# ── Firebase Cloud Messaging (FCM) ────────────────────────────────────────────
# 1. https://console.firebase.google.com → Project Settings → Service Accounts
# 2. "Generate new private key" → download JSON
# 3. Minify the JSON (remove whitespace) and paste as a single line below
#    OR base64 encode it: node -e "console.log(Buffer.from(JSON.stringify(require('./sa.json'))).toString('base64'))"
FIREBASE_SERVICE_ACCOUNT_JSON=
