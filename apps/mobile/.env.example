# Smart Mandi Mobile — Environment Variables Reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# This file is committed to version control — NEVER put real secrets here.
#
# NOTE: This is a bare React Native project (no Expo, no react-native-config).
#       Values here are referenced manually in src/api/constants.ts.
#       If you add react-native-config later, wire these vars automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── API Base URL ───────────────────────────────────────────────────────────────
# Dev: your machine's LAN IP when testing over WiFi
#   Find it: ipconfig (Windows) | ifconfig (Mac/Linux)
API_BASE_URL_DEV=http://<YOUR_LAN_IP>:3000/api/v1

# Production: your EC2 IP, ALB DNS, or custom domain
#   Example: http://api.smartmandi.app/api/v1
API_BASE_URL_PROD=http://<YOUR_PROD_IP_OR_DOMAIN>/api/v1

# ── Android Signing (release builds only) ─────────────────────────────────────
# Generate keystore: keytool -genkeypair -v -keystore release.keystore -alias smart_mandi -keyalg RSA -keysize 2048 -validity 10000
# ANDROID_KEYSTORE_PATH=../android/app/release.keystore
# ANDROID_KEY_ALIAS=smart_mandi
# ANDROID_KEYSTORE_PASSWORD=<your_keystore_password>
# ANDROID_KEY_PASSWORD=<your_key_password>
